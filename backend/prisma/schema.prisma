// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED_DUE_TO_FUNDS
  CANCELLED
}

enum TradeStatus {
  OPEN
  CLOSED
  FAILED
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  PAYMENT
  FEE
}

enum ProfileUpdateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id            String              @id @default(uuid())
  email         String              @unique
  password      String
  name          String?
  mobile        String?
  address       String?
  panNumber     String?
  aadhaarNumber String?
  role          Role                @default(USER)
  status             UserStatus          @default(ACTIVE)
  /** When true, copy engine skips this user even if subscriptions are ACTIVE. */
  copyTradingPaused  Boolean             @default(false)
  otpCode       String?
  otpExpiry     DateTime?
  telegramChatId       String?              @unique
  telegramLinkToken    String?              @unique
  telegramLinkExpires  DateTime?
  createdAt     DateTime            @default(now())

  deltaApiKeys     DeltaApiKey[]
  exchangeAccounts ExchangeAccount[]
  subscriptions    UserSubscription[]
  trades        Trade[]
  wallet        Wallet?
  transactions  Transaction[]
  invoices      Invoice[]
  pnlRecords    PnLRecord[]
  activities    UserActivity[]
  profileUpdateRequests ProfileUpdateRequest[]
  depositRequests DepositRequest[]
  notifications Notification[]
}

model OtpRecord {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  kind      String
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Strategy {
  id                 String  @id @default(uuid())
  title              String
  description        String
  /** Delta Exchange (India) API key for the leader account whose positions are copied. */
  masterApiKey       String  @default("")
  masterApiSecret    String  @default("")
  performanceMetrics Json?
  slippage           Float   @default(0.5)
  monthlyFee         Float
  profitShare        Float   @default(20.0)
  minCapital         Float
  /** When true, new subscribers mirror the strategy's currently open master (leader) positions on Delta (late-join). */
  syncActiveTrades   Boolean @default(false)
  /** Total master unrealized PnL (USD) at or above this value triggers auto-exit (close all master legs). */
  autoExitTarget     Float?
  /** Total master unrealized PnL (USD) at or below negative this value triggers auto-exit (e.g. 5 → exit at -$5). */
  autoExitStopLoss   Float?
  createdAt          DateTime @default(now())

  subscriptions UserSubscription[]
  trades        Trade[]
  pnlRecords    PnLRecord[]
  invoices      Invoice[]
}

model UserSubscription {
  id                 String              @id @default(uuid())
  userId             String
  strategyId         String
  exchangeAccountId  String?
  multiplier         Float               @default(1.0)
  status             SubscriptionStatus  @default(ACTIVE)
  joinedDate         DateTime            @default(now())

  user             User             @relation(fields: [userId], references: [id])
  strategy         Strategy         @relation(fields: [strategyId], references: [id])
  exchangeAccount  ExchangeAccount? @relation(fields: [exchangeAccountId], references: [id], onDelete: SetNull)
}

model ExchangeAccount {
  id        String   @id @default(uuid())
  userId    String
  nickname  String
  exchange  String   @default("Delta")
  apiKey    String
  apiSecret String
  createdAt DateTime @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions  UserSubscription[]

  @@index([userId])
}

model Trade {
  id              String      @id @default(uuid())
  userId          String
  strategyId      String
  symbol          String
  side            String
  size            Float
  entryPrice      Float
  exitPrice       Float?
  pnl             Float?
  tradePnl        Float       @default(0)
  tradingFee      Float       @default(0)
  revenueShareAmt Float       @default(0)
  status          TradeStatus @default(OPEN)
  /** Why the trade was closed or marked failed (set by trade engine / admin). */
  exitReason      String?
  createdAt       DateTime    @default(now())

  user       User        @relation(fields: [userId], references: [id])
  strategy   Strategy    @relation(fields: [strategyId], references: [id])
}

model Wallet {
  id          String        @id @default(uuid())
  userId      String        @unique
  balance     Float         @default(0.0)
  pendingFees Float         @default(0.0)
  overdueDays Int           @default(0)

  user         User              @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String
  amount    Float
  type      String
  status    String
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model Transaction {
  id        String            @id @default(uuid())
  userId    String
  amount    Float
  type      TransactionType   @default(PAYMENT)
  utrNumber String?           @unique
  status    TransactionStatus @default(PENDING)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ProfileUpdateRequest {
  id            String              @id @default(uuid())
  userId        String
  address       String?
  panNumber     String?
  aadhaarNumber String?
  status        ProfileUpdateStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  reviewedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model DepositRequest {
  id            String   @id @default(uuid())
  userId        String
  amount        Float
  transactionId String
  screenshotUrl String?
  status        String   @default("PENDING")
  adminReason   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model DownloadFile {
  id        String   @id @default(uuid())
  fileName  String
  filePath  String
  fileType  String
  status    String   @default("READY")
  createdAt DateTime @default(now())
}

model DeltaApiKey {
  id        String @id @default(uuid())
  userId    String
  nickname  String
  apiKey    String
  apiSecret String

  user      User   @relation(fields: [userId], references: [id])
}

model Invoice {
  id          String        @id @default(uuid())
  userId      String
  strategyId  String
  month       Int
  year        Int
  totalPnl    Float
  amountDue   Float
  dueDate     DateTime
  status      InvoiceStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  strategy Strategy @relation(fields: [strategyId], references: [id])

  @@unique([userId, strategyId, month, year])
  @@index([status])
}

model PnLRecord {
  id               String   @id @default(uuid())
  userId           String
  strategyId       String
  profitAmount     Float
  commissionAmount Float
  timestamp        DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  strategy Strategy @relation(fields: [strategyId], references: [id])
}
