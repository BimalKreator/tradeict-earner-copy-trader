// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  OVERDUE
}

enum TradeStatus {
  OPEN
  CLOSED
  FAILED
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

model User {
  id            String              @id @default(uuid())
  email         String              @unique
  password      String
  name          String?
  mobile        String?
  role          Role                @default(USER)
  status        UserStatus          @default(ACTIVE)
  otpCode       String?
  otpExpiry     DateTime?
  telegramChatId       String?              @unique
  telegramLinkToken    String?              @unique
  telegramLinkExpires  DateTime?
  createdAt     DateTime            @default(now())

  deltaApiKeys     DeltaApiKey[]
  exchangeAccounts ExchangeAccount[]
  subscriptions    UserSubscription[]
  trades        Trade[]
  wallet        Wallet?
  transactions  Transaction[]
  invoices      Invoice[]
  pnlRecords    PnLRecord[]
  activities    UserActivity[]
}

model OtpRecord {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  kind      String
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Strategy {
  id                 String  @id @default(uuid())
  title              String
  description        String
  cosmicEmail        String  @default("")
  cosmicPassword     String  @default("")
  performanceMetrics Json?
  /** Visual Scraper Studio: slot key → CSS selector (e.g. symbol, size, side). */
  scraperMappings Json?
  slippage           Float   @default(0.5)
  monthlyFee         Float
  profitShare        Float   @default(20.0)
  minCapital         Float
  createdAt          DateTime @default(now())

  subscriptions UserSubscription[]
  trades        Trade[]
  pnlRecords    PnLRecord[]
}

model UserSubscription {
  id                 String              @id @default(uuid())
  userId             String
  strategyId         String
  exchangeAccountId  String?
  multiplier         Float               @default(1.0)
  status             SubscriptionStatus  @default(ACTIVE)
  joinedDate         DateTime            @default(now())

  user             User             @relation(fields: [userId], references: [id])
  strategy         Strategy         @relation(fields: [strategyId], references: [id])
  exchangeAccount  ExchangeAccount? @relation(fields: [exchangeAccountId], references: [id], onDelete: SetNull)
  invoices         Invoice[]
}

model ExchangeAccount {
  id        String   @id @default(uuid())
  userId    String
  nickname  String
  exchange  String   @default("Delta")
  apiKey    String
  apiSecret String
  createdAt DateTime @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions  UserSubscription[]

  @@index([userId])
}

model Trade {
  id         String      @id @default(uuid())
  userId     String
  strategyId String
  symbol     String
  side       String
  size       Float
  entryPrice Float
  exitPrice  Float?
  pnl        Float?
  status     TradeStatus @default(OPEN)
  createdAt  DateTime    @default(now())

  user       User        @relation(fields: [userId], references: [id])
  strategy   Strategy    @relation(fields: [strategyId], references: [id])
}

model Wallet {
  id          String        @id @default(uuid())
  userId      String        @unique
  balance     Float         @default(0.0)
  pendingFees Float         @default(0.0)
  overdueDays Int           @default(0)

  user         User              @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String
  amount    Float
  type      String
  status    String
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model Transaction {
  id        String            @id @default(uuid())
  userId    String
  amount    Float
  utrNumber String?           @unique
  status    TransactionStatus @default(PENDING)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DeltaApiKey {
  id        String @id @default(uuid())
  userId    String
  nickname  String
  apiKey    String
  apiSecret String

  user      User   @relation(fields: [userId], references: [id])
}

model Invoice {
  id               String        @id @default(uuid())
  userId           String
  amount           Float
  status           InvoiceStatus @default(UNPAID)
  dueDate          DateTime
  createdAt        DateTime      @default(now())
  subscriptionId   String?
  billingPeriodEnd DateTime?

  user         User              @relation(fields: [userId], references: [id])
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, billingPeriodEnd])
}

model PnLRecord {
  id               String   @id @default(uuid())
  userId           String
  strategyId       String
  profitAmount     Float
  commissionAmount Float
  timestamp        DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  strategy Strategy @relation(fields: [strategyId], references: [id])
}
