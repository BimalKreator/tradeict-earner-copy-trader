// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
  EXECUTIVE
  MANAGER
  SENIOR_MANAGER
}

/** Partner commission wallet state machine (Earned → Payable → Withdrawable). */
enum CommissionLedgerStatus {
  EARNED
  PAYABLE
  WITHDRAWABLE
  /** Set when included in an approved monthly payout (Phase 9). */
  WITHDRAWN
}

/** Which sales tier earned a commission row (snapshot at distribution time). */
enum SalesTier {
  EXECUTIVE
  MANAGER
  SENIOR_MANAGER
}

/** Member referral nomination lifecycle (Phase 1 — admin approves in Phase 2). */
enum ReferralRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/** Partner monthly payout request lifecycle (Phase 9). */
enum PayoutRequestStatus {
  PENDING
  COMPLETED
}

/** Partner profile lifecycle — suspended when role is downgraded to USER (Phase 10). */
enum AffiliateProfileStatus {
  ACTIVE
  SUSPENDED
}

/** Sales role a partner may nominate a user for (Senior Manager / Manager requests). */
enum NominatedSalesRole {
  MANAGER
  EXECUTIVE
}

enum MemberUpgradeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED_DUE_TO_FUNDS
  CANCELLED
}

enum TradeStatus {
  OPEN
  CLOSED
  FAILED
}

/** Exchange leg ledger — ties each open/close to a strategy (and user or master). */
enum TradePositionStatus {
  OPEN
  CLOSED
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  PAYMENT
  FEE
}

enum ProfileUpdateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum FutureHedgeBatchTrend {
  UPTREND
  DOWNTREND
}

model User {
  id            String              @id @default(uuid())
  email         String              @unique
  password      String
  name          String?
  mobile        String?
  address       String?
  panNumber     String?
  aadhaarNumber String?
  role          Role                @default(USER)
  /** Immediate upline in the sales hierarchy (Executive→Manager, Manager→Senior Manager). */
  parentId      String?
  /** Team member who referred/acquired this user (set at signup — Phase 4). */
  acquiredById  String?
  status             UserStatus          @default(ACTIVE)
  /** When true, copy engine skips this user even if subscriptions are ACTIVE. */
  copyTradingPaused  Boolean             @default(false)
  /** Crypto arbitrage bot enabled for this user. */
  cryptoArbitrageEnabled       Boolean @default(false)
  /** Simulated / platform crypto arbitrage balance (USDT). */
  cryptoBalance                Float   @default(0.0)
  /** Percent of cryptoBalance allocated per arbitrage trade. */
  cryptoCapitalPerTradePercent Float   @default(10.0)
  /** When set, this user's arbitrage trades UI reads from the source user's trade history. */
  arbitrageSourceUserId        String?
  otpCode       String?
  otpExpiry     DateTime?
  telegramChatId       String?              @unique
  telegramLinkToken    String?              @unique
  telegramLinkExpires  DateTime?
  createdAt     DateTime            @default(now())

  deltaApiKeys     DeltaApiKey[]
  exchangeAccounts ExchangeAccount[]
  subscriptions    UserStrategySubscription[]
  trades           Trade[]
  tradePositions   TradePosition[]
  wallet        Wallet?
  transactions  Transaction[]
  invoices      Invoice[]
  pnlRecords    PnLRecord[]
  activities    UserActivity[]
  profileUpdateRequests ProfileUpdateRequest[]
  depositRequests      DepositRequest[]
  paymentTransactions  PaymentTransaction[]
  notifications        Notification[]
  arbitrageTrades      ArbitrageTrade[]
  arbitrageWithdrawals ArbitrageWithdrawal[]
  arbitrageSourceUser  User?                 @relation("ArbitrageSource", fields: [arbitrageSourceUserId], references: [id], onDelete: SetNull)
  arbitrageSourceFollowers User[]            @relation("ArbitrageSource")
  tickets              Ticket[]
  ticketMessages       TicketMessage[]
  parent               User?               @relation("SalesHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  directReports        User[]              @relation("SalesHierarchy")
  acquiredBy           User?               @relation("UserAcquisition", fields: [acquiredById], references: [id], onDelete: SetNull)
  acquiredUsers        User[]              @relation("UserAcquisition")
  affiliateProfile     AffiliateProfile?
  commissionsEarned    CommissionLedger[]  @relation("CommissionBeneficiary")
  commissionsSourced   CommissionLedger[]  @relation("CommissionSource")
  affiliateUpgradesPerformed AffiliateProfile[] @relation("AffiliateUpgradedBy")
  payoutRequests       PayoutRequest[]
  partnerPayoutsCompleted PayoutRequest[]    @relation("PayoutCompletedBy")
  upgradeRequestsSubmitted MemberUpgradeRequest[] @relation("UpgradeRequestRequester")
  upgradeRequestsAsParent  MemberUpgradeRequest[] @relation("UpgradeRequestAssignedParent")
  referralRequestsSubmitted ReferralRequest[]     @relation("ReferralRequestSponsor")

  @@index([parentId])
  @@index([acquiredById])
  @@index([role])
}

model OtpRecord {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  kind      String
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Strategy {
  id                 String  @id @default(uuid())
  title              String
  description        String
  /** Delta Exchange (India) API key for the leader account whose positions are copied. */
  masterApiKey       String  @default("")
  masterApiSecret    String  @default("")
  performanceMetrics Json?
  slippage           Float   @default(0.5)
  monthlyFee         Float
  profitShare        Float   @default(20.0)
  minCapital         Float
  /** When false, copy-trading and hedge automation skip this strategy. */
  isActive             Boolean @default(true)
  /** When true, new subscribers mirror the strategy's currently open master (leader) positions on Delta (late-join). */
  syncActiveTrades   Boolean @default(false)
  /** Total master unrealized PnL (USD) at or above this value triggers auto-exit (close all master legs). */
  autoExitTarget     Float?
  /** Total master unrealized PnL (USD) at or below negative this value triggers auto-exit (e.g. 5 → exit at -$5). */
  autoExitStopLoss   Float?
  /** When true, target/stop-loss thresholds may trigger automatic master flat + follower copy. */
  autoExitEnabled    Boolean @default(false)
  createdAt          DateTime @default(now())

  subscriptions      UserStrategySubscription[]
  trades             Trade[]
  tradePositions     TradePosition[]
  pnlRecords         PnLRecord[]
  invoices           Invoice[]
  futureHedgeConfig  FutureHedgeConfig?
}

/** Automation settings for the "Future Hedge Strategy" leader bot. */
model FutureHedgeConfig {
  id              String   @id @default(uuid())
  strategyId      String   @unique
  isAutoEnabled   Boolean  @default(false)
  baseLots        Int      @default(1)
  emaPeriod       Int      @default(200)
  adjustmentPct   Float    @default(0.5)
  targetProfitUsd Float    @default(10.0)
  /** When true, auto-flat master legs when BTC price breaches breakeven bounds. */
  isBreakevenExitEnabled Boolean @default(false)
  /** Lower/upper breakeven bound (USD); either or both may be set. */
  breakevenPrice1        Float?
  breakevenPrice2        Float?
  /** Groups a run of hedge adjustments; cleared when a batch completes. */
  currentBatchId  String?
  /** BTC perp price anchor for the adjustment grid (updated each entry/adjustment). */
  lastEntryPrice        Float?
  /** Direction locked when the batch opens. */
  batchTrend            FutureHedgeBatchTrend?
  /** Option product id (same expiry for all adjustments in the batch). */
  batchOptionProductId  String?
  batchOptionExpiryMs   BigInt?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  strategy    Strategy                 @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  executions  FutureHedgeExecution[]
}

model FutureHedgeExecution {
  id        String   @id @default(uuid())
  batchId   String
  configId  String
  kind      String
  leg       String
  side      String
  symbol    String
  lots      Int
  price     Float?
  orderId   String?
  createdAt DateTime @default(now())

  config FutureHedgeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([batchId, createdAt])
  @@index([configId, batchId])
}

/// Per-user subscription to a single copy-trading strategy (table: `UserSubscription`).
model UserStrategySubscription {
  id                 String              @id @default(uuid())
  userId             String
  strategyId         String
  exchangeAccountId  String?
  /** Scales master contract size for this user on this strategy only. */
  multiplier         Float               @default(1.0)
  /** When true, copy engine may open/adjust trades for this user on this strategy. */
  isActive           Boolean             @default(true)
  status             SubscriptionStatus  @default(ACTIVE)
  /** Follower copy state vs master: SYNCED, ERROR, etc. */
  syncStatus         String              @default("SYNCED")
  /** Last copy failure reason (e.g. Insufficient Funds). */
  syncError          String?
  joinedDate         DateTime            @default(now())

  user             User             @relation(fields: [userId], references: [id])
  strategy         Strategy         @relation(fields: [strategyId], references: [id])
  exchangeAccount  ExchangeAccount? @relation(fields: [exchangeAccountId], references: [id], onDelete: SetNull)

  @@unique([userId, strategyId])
  @@map("UserSubscription")
}

model ExchangeAccount {
  id        String   @id @default(uuid())
  userId    String
  nickname  String
  exchange  String   @default("Delta")
  apiKey    String
  apiSecret String
  createdAt DateTime @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions  UserStrategySubscription[]

  @@index([userId])
}

model Trade {
  id              String      @id @default(uuid())
  userId          String
  strategyId      String
  symbol          String
  side            String
  size            Float
  entryPrice      Float
  exitPrice       Float?
  pnl             Float?
  tradePnl        Float       @default(0)
  tradingFee      Float       @default(0)
  revenueShareAmt Float       @default(0)
  status          TradeStatus @default(OPEN)
  /** Why the trade was closed or marked failed (set by trade engine / admin). */
  exitReason      String?
  /** Stable id for copy dedup (master fill × follower leg). */
  clientOrderId   String?     @unique
  /** Admin-injected test trade — no exchange execution. */
  isDummy         Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now()) @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  strategy   Strategy    @relation(fields: [strategyId], references: [id])
}

/// Per-order leg registry so copy trades never mix across strategies.
model TradePosition {
  id            String              @id @default(uuid())
  /** Null when `isMaster` is true (strategy leader account). */
  userId        String?
  isMaster      Boolean             @default(false)
  strategyId    String
  symbol        String
  side          String
  quantity      Float
  entryPrice    Float
  clientOrderId String              @unique
  status        TradePositionStatus @default(OPEN)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([strategyId, status])
  @@index([userId, strategyId, status])
  @@index([isMaster, strategyId, status, symbol, side])
}

model Wallet {
  id          String        @id @default(uuid())
  userId      String        @unique
  balance     Float         @default(0.0)
  pendingFees Float         @default(0.0)
  overdueDays Int           @default(0)

  user         User              @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String
  amount    Float
  type      String
  status    String
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model Transaction {
  id        String            @id @default(uuid())
  userId    String
  amount    Float
  type      TransactionType   @default(PAYMENT)
  utrNumber String?           @unique
  status    TransactionStatus @default(PENDING)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ProfileUpdateRequest {
  id            String              @id @default(uuid())
  userId        String
  address       String?
  panNumber     String?
  aadhaarNumber String?
  status        ProfileUpdateStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  reviewedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model SystemSettings {
  id                  String   @id @default("global")
  pgFeePercent        Float    @default(2.36)
  allowedEmailDomains String   @default("gmail.com,yahoo.com,hotmail.com,outlook.com")
  /** USD → INR rate for Razorpay and wallet INR display. */
  usdInrRate          Float    @default(83)
  maintenanceMode     Boolean  @default(false)
  maintenanceMessage  String?
  /** Max total partner commission % of app revenue per profit event (scale-down cap). */
  partnerMaxCommissionPct       Float @default(8)
  /** Executive directly acquired the trader (USER) — % of app revenue. */
  partnerExecutiveDirectPct     Float @default(5)
  /** Manager upline when Executive acquired the trader. */
  partnerManagerUnderExecPct    Float @default(2)
  /** Director upline when Executive acquired the trader (and Manager exists). */
  partnerDirectorUnderExecPct   Float @default(1)
  /** Manager is chain entry (acquired trader or Manager's own trade upline). */
  partnerManagerDirectPct       Float @default(6)
  /** Director upline when Manager is chain entry. */
  partnerDirectorUnderMgrPct    Float @default(2)
  /** Director is chain entry (acquired trader). */
  partnerDirectorDirectPct      Float @default(8)
  updatedAt           DateTime @updatedAt
}

model PaymentTransaction {
  id                String            @id @default(uuid())
  userId            String
  method            String
  baseAmountInr     Float
  feeAmountInr      Float             @default(0)
  totalAmountInr    Float
  netCreditUsd      Float
  referenceId       String?
  razorpayOrderId   String?
  razorpayPaymentId String?           @unique
  depositRequestId  String?           @unique
  status            TransactionStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositRequest     DepositRequest?    @relation(fields: [depositRequestId], references: [id])
  commissionLedgers  CommissionLedger[]

  @@index([userId, createdAt])
  @@index([status])
}

model DepositRequest {
  id            String   @id @default(uuid())
  userId        String
  amount        Float
  method        String   @default("UPI")
  baseAmountInr Float?
  feeAmountInr  Float    @default(0)
  netCreditUsd  Float?
  transactionId String
  screenshotUrl String?
  status        String   @default("PENDING")
  adminReason   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction?

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model DownloadFile {
  id        String   @id @default(uuid())
  fileName  String
  filePath  String
  fileType  String
  status    String   @default("READY")
  createdAt DateTime @default(now())
}

model DeltaApiKey {
  id        String @id @default(uuid())
  userId    String
  nickname  String
  apiKey    String
  apiSecret String

  user      User   @relation(fields: [userId], references: [id])
}

model Invoice {
  id          String        @id @default(uuid())
  userId      String
  strategyId  String
  month       Int
  year        Int
  totalPnl    Float
  amountDue   Float
  dueDate     DateTime
  status      InvoiceStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  strategy          Strategy           @relation(fields: [strategyId], references: [id])
  commissionLedgers CommissionLedger[]

  @@unique([userId, strategyId, month, year])
  @@index([status])
}

model PnLRecord {
  id               String   @id @default(uuid())
  userId           String
  strategyId       String
  profitAmount     Float
  commissionAmount Float
  /** Admin-injected test PnL — triggers same commission path without exchange. */
  isDummy          Boolean  @default(false)
  timestamp        DateTime @default(now())

  user              User               @relation(fields: [userId], references: [id])
  strategy          Strategy           @relation(fields: [strategyId], references: [id])
  commissionLedgers CommissionLedger[]
}

/** Admin-managed tier benefits, commission rates, and promotion thresholds. */
model TierConfig {
  id                    String    @id @default(uuid())
  tierLevel             SalesTier @unique
  /** Direct referral / acquisition commission %. */
  directCommissionRate  Float
  /** Team (downline) override commission %. */
  teamCommissionRate    Float
  /** Network / upline commission %. */
  networkCommissionRate Float
  /** Active direct referrals required to reach this tier. */
  minReferralsRequired  Int       @default(0)
  /** Display benefits for partner milestone UI (JSON string array). */
  benefits              Json      @default("[]")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

/** Partner submits a referred email; admin approves in Phase 2. */
model ReferralRequest {
  id            String                @id @default(uuid())
  sponsorId     String
  referredEmail String
  status        ReferralRequestStatus @default(PENDING)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  sponsor User @relation("ReferralRequestSponsor", fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
  @@index([status, createdAt])
  @@index([referredEmail])
}

/**
 * Partner / IB profile — one row per upgraded team member (Executive, Manager, Senior Manager).
 * Stats are cached for dashboards; authoritative counts can be recomputed from relations.
 */
model AffiliateProfile {
  id                    String                 @id @default(uuid())
  userId                String                 @unique
  /** Public referral code for acquisition links (Phase 4). */
  referralCode          String                 @unique
  /** Users directly acquired by this member (`User.acquiredById`). */
  directAcquiredCount   Int                    @default(0)
  /** Sum of subscribed capital under direct + downline network (USD, cached). */
  networkAum            Float                  @default(0)
  /** SUSPENDED when team role is downgraded — profile retained for ledger history. */
  status                AffiliateProfileStatus @default(ACTIVE)
  upgradedAt            DateTime               @default(now())
  upgradedById          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  user         User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  upgradedBy   User? @relation("AffiliateUpgradedBy", fields: [upgradedById], references: [id], onDelete: SetNull)

  @@index([upgradedById])
}

/** Partner nomination for admin review before sales-role upgrade. */
model MemberUpgradeRequest {
  id               String                     @id @default(uuid())
  targetUserEmail  String
  requestedRole    NominatedSalesRole
  requesterId      String
  assignedParentId String
  status           MemberUpgradeRequestStatus @default(PENDING)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  requester      User @relation("UpgradeRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  assignedParent User @relation("UpgradeRequestAssignedParent", fields: [assignedParentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([requesterId])
  @@index([targetUserEmail])
}

/**
 * Immutable commission accrual ledger for the partner program.
 * Amounts flow: EARNED (profit booked) → PAYABLE (user paid revenue share) → WITHDRAWABLE (30d+).
 */
model CommissionLedger {
  id                  String                 @id @default(uuid())
  /** Calendar date of the source user's booked profit (UTC day). */
  profitDate          DateTime               @db.Date
  /** Trader whose revenue share generated this commission. */
  sourceUserId        String
  /** Team member receiving the commission cut. */
  beneficiaryUserId   String
  amount              Float
  /** App revenue-share $ this row was calculated from (e.g. $15 of user's due). */
  appRevenueBase      Float
  /** Rate applied at distribution (e.g. 5 = 5%). */
  commissionRate      Float
  /** Sales tier of beneficiary at accrual time. */
  beneficiaryTier     SalesTier
  status              CommissionLedgerStatus @default(EARNED)
  /** profitDate + 30 days — earliest withdrawable after PAYABLE. */
  unlockDate          DateTime
  /** Prevents double-distribution for the same profit event × beneficiary. */
  idempotencyKey      String                 @unique
  /** Set when source user pays invoice / revenue share (Phase 6). */
  invoiceId           String?
  /** Optional link to the PnL / profit event that triggered accrual (Phase 5). */
  pnlRecordId         String?
  /** Set when payment webhook confirms revenue-share settlement (Phase 6). */
  paymentTransactionId String?
  /** Set when included in a partner payout request (Phase 9). */
  payoutRequestId     String?
  earnedAt            DateTime               @default(now())
  payableAt           DateTime?
  withdrawableAt      DateTime?
  withdrawnAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  sourceUser          User                @relation("CommissionSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  beneficiaryUser     User                @relation("CommissionBeneficiary", fields: [beneficiaryUserId], references: [id], onDelete: Cascade)
  invoice             Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  pnlRecord           PnLRecord?          @relation(fields: [pnlRecordId], references: [id], onDelete: SetNull)
  paymentTransaction  PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)
  payoutRequest       PayoutRequest?      @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)

  @@index([beneficiaryUserId, status])
  @@index([payoutRequestId])
  @@index([sourceUserId, profitDate])
  @@index([status, unlockDate])
  @@index([invoiceId])
  @@index([profitDate])
}

/** Monthly partner commission withdrawal request (Phase 9). */
model PayoutRequest {
  id            String              @id @default(uuid())
  userId        String
  amount        Float
  status        PayoutRequestStatus @default(PENDING)
  requestedAt   DateTime            @default(now())
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedBy       User?              @relation("PayoutCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  commissionLedgers CommissionLedger[]

  @@index([userId, status])
  @@index([status, requestedAt])
}

model ArbitrageTrade {
  id          String   @id @default(uuid())
  userId      String
  token       String
  qty         Float
  buyPrice    Float
  sellPrice   Float
  buyDex      String
  sellDex     String
  feePercent  Float
  feeAmount   Float
  netProfit   Float
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ArbitrageWithdrawal {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  date      DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model DiscountCoupon {
  id                 String   @id @default(uuid())
  code               String   @unique
  discountPercentage Int
  maxUses            Int
  usedCount          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Ticket {
  id        String       @id @default(uuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([userId, status])
  @@index([status, updatedAt])
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String
  isAdmin   Boolean  @default(false)
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}
